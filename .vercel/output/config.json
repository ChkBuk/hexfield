{
	"version": 3,
	"routes": [
		{
			"src": "/404",
			"headers": {
				"Location": "/404/"
			},
			"status": 308
		},
		{
			"src": "/about",
			"headers": {
				"Location": "/about/"
			},
			"status": 308
		},
		{
			"src": "/blog/([^/]+?)",
			"headers": {
				"Location": "/blog/$1/"
			},
			"status": 308
		},
		{
			"src": "/blog",
			"headers": {
				"Location": "/blog/"
			},
			"status": 308
		},
		{
			"src": "/contact/thanks",
			"headers": {
				"Location": "/contact/thanks/"
			},
			"status": 308
		},
		{
			"src": "/contact",
			"headers": {
				"Location": "/contact/"
			},
			"status": 308
		},
		{
			"src": "/cookies",
			"headers": {
				"Location": "/cookies/"
			},
			"status": 308
		},
		{
			"src": "/portfolio",
			"headers": {
				"Location": "/portfolio/"
			},
			"status": 308
		},
		{
			"src": "/privacy",
			"headers": {
				"Location": "/privacy/"
			},
			"status": 308
		},
		{
			"src": "/services",
			"headers": {
				"Location": "/services/"
			},
			"status": 308
		},
		{
			"src": "/terms",
			"headers": {
				"Location": "/terms/"
			},
			"status": 308
		},
		{
			"src": "^/assets/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^\\/_image$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/contact\\/$",
			"dest": "_render"
		},
		{
			"src": "/.*",
			"dest": "/404.html",
			"status": 404
		}
	]
}