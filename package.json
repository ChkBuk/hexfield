{
  "name": "hexfield-website",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Hexfield Pty Ltd — Australian IT services marketing site (Astro + Tailwind).",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "node scripts/build-og-image.mjs",
    "build": "astro build",
    "postbuild": "pagefind --site dist --output-subdir pagefind && node scripts/check-internal-links.mjs",
    "preview": "astro preview --host",
    "typecheck": "astro check",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "3.2.1",
    "@astrojs/tailwind": "^5.1.2",
    "@fontsource/roboto": "^5.2.10",
    "astro": "^4.16.7",
    "pagefind": "^1.5.2",
    "tailwindcss": "^3.4.13"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "typescript": "^5.9.3"
  }
}
