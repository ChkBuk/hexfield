---
import SlidesLayout from '~/layouts/SlidesLayout.astro';
import SiteSearch from '~/components/SiteSearch.astro';

const popular = [
  { label: 'Forms Digitalization', href: '/services/#forms' },
  { label: 'Web Design',           href: '/services/#web-design' },
  { label: 'Web Development',      href: '/services/#web' },
  { label: 'System Design',        href: '/services/#systems' },
  { label: 'SEO',                  href: '/services/#seo' },
  { label: 'Portfolio',            href: '/portfolio/' },
  { label: 'About',                href: '/about/' },
  { label: 'Contact',              href: '/contact/' },
  { label: 'Insights',             href: '/blog/' },
  { label: 'Home',                 href: '/' },
];
---
<SlidesLayout
  title="Page not found | Hexfield"
  description="Sorry, the page you were looking for does not exist."
  path="/404/"
  slideCount={1}
  initialVariant="dark"
>

  <section class="slide slide-dark slide-scroll" data-variant="dark">
    <div class="slide-inner longform" style="text-align: center;">
      <p class="slide-eyebrow" style="justify-self: center;">404</p>
      <h1>We couldn't<br/>find that <span class="hl-pill">page</span></h1>
      <p class="meta" style="opacity: 0.8;">The page you were looking for does not exist or has moved.<br/>Try searching, or jump to one of the most-visited pages.</p>

      <div style="max-width: 640px; margin: 0 auto 2.5rem;">
        <SiteSearch label="Search Hexfield" placeholder="Search for a service or article…" />
      </div>

      <p class="slide-eyebrow" style="justify-self: center;">Popular pages</p>
      <ul class="grid gap-px md:grid-cols-2 list-none p-0 bg-graphite-900" style="border-radius: 2px; overflow: hidden; margin: 0 auto 2.5rem; max-width: 720px; text-align: left;">
        {popular.map((p) => (
          <li>
            <a href={p.href} class="dark-card no-underline" style="border-radius: 0; min-height: 0; padding: 16px 20px; display: flex; align-items: center; justify-content: space-between;">
              <span style="color: #FFFFFF; font-weight: 700;">{p.label}</span>
              <span style="color: #C8F031; font-weight: 700;">→</span>
            </a>
          </li>
        ))}
      </ul>

      <a href="/" class="btn-pill-lime" style="align-self: center;">Back to home</a>
    </div>
  </section>

</SlidesLayout>
