---
import SlidesLayout from '~/layouts/SlidesLayout.astro';
import { SITE } from '~/config/site';

const title = `Thanks — we'll be in touch | ${SITE.name}`;
const description = `Thank you for contacting ${SITE.legalName}. I'll respond within one business day.`;
---
<SlidesLayout {title} {description} path="/contact/thanks/" slideCount={1} initialVariant="dark">

  <section class="slide slide-dark" data-variant="dark">
    <div class="slide-inner text-center" style="display: grid; place-items: center;">
      <p class="slide-eyebrow" style="justify-self: center;">Message received</p>
      <h1 class="h-display mb-6">Thanks — I'll<br/>be in <span class="hl-pill">touch</span></h1>
      <p class="lead mb-10" style="margin-inline: auto;">
        I've received your enquiry and will reply within one business day. If it's urgent,
        give me a call on <a href={`tel:${SITE.phoneTel}`} style="color: #C8F031; font-weight: 700;">{SITE.phoneDisplay}</a>.
      </p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/" class="btn-pill-lime">Back to home</a>
        <a href="/portfolio/" class="btn-pill-ghost">See recent work</a>
      </div>
    </div>
  </section>

</SlidesLayout>
