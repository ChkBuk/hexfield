---
import BaseLayout from '~/layouts/BaseLayout.astro';
const title = 'Thanks — we\'ll be in touch | Hexfield';
const description = 'Thank you for contacting Hexfield Pty Ltd. We will respond within one business day.';
---
<BaseLayout {title} {description} path="/contact/thanks/" robots="noindex,follow">
  <section class="container-narrow section text-center max-w-2xl">
    <h1 class="h1 mb-4">Thanks — we'll be in touch</h1>
    <p class="text-lg prose-body mx-auto mb-8">
      We have received your enquiry and will respond within one business day.
      If it is urgent, please call us on
      <a href="tel:+61280000000" class="font-semibold">+61 2 8000 0000</a>.
    </p>
    <a href="/" class="btn-secondary">Back to home</a>
  </section>
</BaseLayout>
