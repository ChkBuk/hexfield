---
import SlidesLayout from '~/layouts/SlidesLayout.astro';
import { getCollection } from 'astro:content';
import { SITE } from '~/config/site';
import { breadcrumbSchema, blogPostingSchema } from '~/lib/schema';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const path = `/blog/${post.slug}/`;

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Insights', path: '/blog/' },
  { name: post.data.title, path },
];

const schemas = [
  breadcrumbSchema(crumbs),
  blogPostingSchema({
    title: post.data.title,
    description: post.data.description,
    path,
    publishedTime: post.data.publishedDate.toISOString(),
    modifiedTime: post.data.updatedDate?.toISOString(),
    author: post.data.author,
  }),
];

const fmt = new Intl.DateTimeFormat('en-AU', { day: 'numeric', month: 'long', year: 'numeric' });
---
<SlidesLayout
  title={`${post.data.title} | ${SITE.name} Insights`}
  description={post.data.description}
  {path}
  {schemas}
  slideCount={1}
  initialVariant="dark"
>

  <section class="slide slide-dark slide-scroll" data-variant="dark">
    <div class="slide-inner longform">
      <p class="slide-eyebrow">Insights</p>
      <h1>{post.data.title}</h1>
      <p class="meta">
        <time datetime={post.data.publishedDate.toISOString()}>{fmt.format(post.data.publishedDate)}</time>
        &middot; By {post.data.author}
      </p>
      <p style="font-size: 1.125rem; margin-bottom: 2rem; opacity: 0.9;">{post.data.description}</p>
      <Content />
    </div>
  </section>

</SlidesLayout>
