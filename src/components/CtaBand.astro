---
export interface Props {
  heading?: string;
  sub?: string;
  ctaLabel?: string;
  ctaHref?: string;
}
const {
  heading = "Let's talk about your IT.",
  sub = 'Tell us about your business and we will respond within one business day.',
  ctaLabel = 'Contact Hexfield',
  ctaHref = '/contact/',
} = Astro.props;
---
<section class="section">
  <div class="container-narrow">
    <div class="rounded-2xl bg-gradient-to-br from-brand-700 to-brand-900 text-white px-6 py-12 md:px-12 md:py-16 text-center">
      <h2 class="h2 mb-3">{heading}</h2>
      <p class="text-brand-50 max-w-2xl mx-auto mb-8">{sub}</p>
      <a href={ctaHref} class="btn-primary bg-white !text-brand-900 hover:bg-brand-50">{ctaLabel}</a>
    </div>
  </div>
</section>
