---
import { SITE } from '~/config/site';

export interface Props {
  title: string;
  description: string;
  path: string; // leading + trailing slash, e.g. "/services/"
  image?: string; // absolute or site-relative; defaults to og-default.png
  robots?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title,
  description,
  path,
  image = '/images/og-default.png',
  robots = 'index,follow,max-image-preview:large',
  type = 'website',
  publishedTime,
  modifiedTime,
} = Astro.props;

const canonical = new URL(path, SITE.url).toString();
const ogImage = image.startsWith('http') ? image : new URL(image, SITE.url).toString();
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content={robots} />
<link rel="canonical" href={canonical} />
<link rel="alternate" hreflang={SITE.hreflang} href={canonical} />
<link rel="alternate" hreflang="x-default" href={canonical} />

<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:alt" content={`${SITE.name} — ${SITE.description.split('.')[0]}.`} />
<meta property="og:locale" content={SITE.defaultLocale} />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
