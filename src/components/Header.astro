---
import { NAV } from '~/config/site';
import Logo from '~/components/Logo.astro';
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== '/' && path.startsWith(href));
---
<header class="sticky top-0 z-40 bg-white/85 backdrop-blur border-b border-ink-200 dark:bg-ink-950/85 dark:border-[#1F2937]">
  <div class="container-narrow flex items-center justify-between h-16">
    <a href="/" class="no-underline text-brand-700 dark:text-brand-500" aria-label="Hexfield home">
      <Logo size={28} />
    </a>

    <nav aria-label="Primary">
      <details class="md:hidden relative">
        <summary class="list-none cursor-pointer p-2 -mr-2" aria-label="Toggle menu">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round"/>
          </svg>
        </summary>
        <ul class="absolute right-0 top-full mt-2 w-56 rounded-lg border border-ink-200 bg-white p-2 shadow-lg dark:bg-ink-950 dark:border-[#1F2937]">
          {NAV.map((item) => (
            <li>
              <a href={item.href}
                 aria-current={isActive(item.href) ? 'page' : undefined}
                 class="block px-3 py-2 rounded-md text-ink-900 dark:text-ink-50 no-underline hover:bg-ink-50 dark:hover:bg-ink-900">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </details>

      <ul class="hidden md:flex items-center gap-1">
        {NAV.map((item) => (
          <li>
            <a href={item.href}
               aria-current={isActive(item.href) ? 'page' : undefined}
               class:list={[
                 'px-3 py-2 rounded-md no-underline font-medium',
                 isActive(item.href)
                   ? 'text-brand-700 dark:text-brand-500'
                   : 'text-ink-700 dark:text-ink-200 hover:text-brand-700 dark:hover:text-brand-500',
               ]}>
              {item.label}
            </a>
          </li>
        ))}
        <li class="ml-2">
          <a href="/contact/" class="btn-primary text-sm py-2 px-4">Get a quote</a>
        </li>
      </ul>
    </nav>
  </div>
</header>
