---
// Hexfield brand mark + optional wordmark. Single source of truth — used
// in the Header and Footer; favicon, public logo and OG image use static
// SVG copies that mirror this design.
//
// The mark is an "HF" monogram set in a rounded squircle. It is monochrome
// and inherits `currentColor`, so it adapts to any surrounding surface
// (dark header / light footer) automatically — the ring's interior is a
// true cut-out (fill-rule: evenodd) so the surface shows through.
export interface Props {
  /** Render size of the square mark in pixels. */
  size?: number;
  /** Show the "Hexfield" wordmark next to the mark. */
  wordmark?: boolean;
  /** Override colour — defaults to `currentColor`. */
  color?: string;
  /** Optional class hook for the wrapping element. */
  class?: string;
}

const { size = 32, wordmark = true, color = 'currentColor', class: klass = '' } = Astro.props;
// The "HF" badge renders a touch larger than the wordmark cap-height for
// presence; the wordmark stays sized off `size` so text is unaffected.
const iconSize = Math.round(size * 1.2);
---
<span class:list={['inline-flex items-center gap-2', klass]} aria-label="Hexfield">
  <svg
    width={iconSize}
    height={iconSize}
    viewBox="0 0 100 100"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    focusable="false"
    fill={color}
  >
    <path fill-rule="evenodd" d="M46 6 L94 6 L94 54 Q94 94 54 94 L6 94 L6 46 Q6 6 46 6 Z M46 17 L83 17 L83 54 Q83 83 54 83 L17 83 L17 46 Q17 17 46 17 Z"/>
    <path d="M27 28 H37 V74 H27 Z M47 28 H57 V74 H47 Z M47 28 H73 V38 H47 Z M27 45 H72 V55 H27 Z"/>
  </svg>
  {wordmark && (
    <span
      class="font-medium tracking-tight"
      style={`font-size: ${Math.round(size * 0.72)}px; color: inherit; line-height: 1;`}
    >Hexfield</span>
  )}
</span>
