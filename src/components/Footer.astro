---
import { SITE } from '~/config/site';
import Logo from '~/components/Logo.astro';
const year = new Date().getFullYear();
---
<footer class="border-t border-ink-200 dark:border-[#1F2937] bg-white dark:bg-ink-950">
  <div class="container-narrow py-12 grid gap-10 md:grid-cols-2 lg:grid-cols-4">
    <div class="lg:col-span-1">
      <div class="mb-3 text-graphite-900 dark:text-ink-50">
        <Logo size={32} />
      </div>
      <p class="text-sm text-graphite-700 dark:text-ink-200 mb-3">{SITE.tagline}</p>
      <address class="not-italic text-sm text-graphite-700 dark:text-ink-200 leading-relaxed">
        {SITE.address.street}<br>
        {SITE.address.locality} {SITE.address.region} {SITE.address.postalCode}<br>
        <a href={`tel:${SITE.phoneTel}`} class="inline-block py-1 mt-2 min-h-[24px]">{SITE.phoneDisplay}</a><br>
        <a href={`mailto:${SITE.email}`} class="inline-block py-1 min-h-[24px]">{SITE.email}</a>
      </address>
    </div>

    <div>
      <h2 class="text-sm font-bold uppercase tracking-wider text-graphite-500 mb-3">Services</h2>
      <ul class="space-y-2 text-sm">
        <li><a href="/services/#forms">Forms Digitalization</a></li>
        <li><a href="/services/#web-design">Web Design</a></li>
        <li><a href="/services/#web">Web Development</a></li>
        <li><a href="/services/#systems">System Design</a></li>
        <li><a href="/services/#seo">SEO</a></li>
      </ul>
    </div>

    <div>
      <h2 class="text-sm font-bold uppercase tracking-wider text-graphite-500 mb-3">Quick links</h2>
      <ul class="space-y-2 text-sm">
        <li><a href="/">Home</a></li>
        <li><a href="/services/">Services</a></li>
        <li><a href="/portfolio/">Portfolio</a></li>
        <li><a href="/about/">About</a></li>
        <li><a href="/contact/">Contact</a></li>
      </ul>
    </div>

    <div>
      <h2 class="text-sm font-bold uppercase tracking-wider text-graphite-500 mb-3">Legal</h2>
      <ul class="space-y-2 text-sm">
        <li><a href="/terms/">Terms of use</a></li>
        <li><a href="/privacy/">Privacy Policy</a></li>
        <li><a href="/cookies/">Cookie Policy</a></li>
        <li>
          <a href={SITE.social.linkedin} rel="noopener" aria-label="LinkedIn" class="inline-flex items-center gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.063 2.063 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="container-narrow border-t border-ink-200 dark:border-[#1F2937] py-6 text-xs text-graphite-500 flex flex-col md:flex-row gap-3 md:items-center md:justify-between">
    <div class="space-y-1">
      <p>&copy; Copyright {SITE.legalName} {year} &middot; All rights reserved</p>
      <p>ABN {SITE.abn} &middot; ACN {SITE.acn}</p>
    </div>
    <ul class="flex flex-wrap gap-x-4 gap-y-1">
      <li><a href="/terms/">Terms of use</a></li>
      <li><a href="/privacy/">Privacy Policy</a></li>
      <li><a href="/cookies/">Cookie Policy</a></li>
    </ul>
  </div>
</footer>
