# Resend — contact form mail delivery.
# Set these as environment variables on Vercel (Project Settings → Environment Variables).
# DO NOT commit a real .env file; .env is gitignored.

# Required — get a key at https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# Optional — defaults to info@hexfield.com.au if unset
CONTACT_TO_EMAIL=info@hexfield.com.au

# Optional — defaults to onboarding@resend.dev (Resend's pre-verified sender).
# Once hexfield.com.au is verified on Resend (DNS records for SPF + DKIM),
# swap to a branded address like noreply@hexfield.com.au.
RESEND_FROM_EMAIL=onboarding@resend.dev
